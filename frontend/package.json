{
  "name": "material-request-frontend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "copy-favicon": "node scripts/generate_icons.js",
    "setup-logo": "node -e \"const fs = require('fs'); const path = require('path'); const svgPath = path.join(__dirname, 'assets', 'Madhura Energy Logo-03 - Copy.svg'); const svg = fs.readFileSync(svgPath, 'utf8'); const match = svg.match(/base64,([^\\\"]+)/); if (match) { const buffer = Buffer.from(match[1], 'base64'); fs.writeFileSync(path.join(__dirname, 'assets', 'logo.png'), buffer); console.log('Logo generated from SVG successfully'); } else { console.error('Could not find base64 image in SVG'); }\"",
    "build": "npx expo export -p web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "axios": "^1.4.0",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.3",
    "twrnc": "^4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "jimp": "^1.6.1"
  },
  "private": true
}
